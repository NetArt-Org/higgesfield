<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="9.0"
    ExtensionBundleId="com.higgesfield"
    ExtensionBundleVersion="0.1.0"
    ExtensionBundleName="Higgesfield"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ExtensionList>
    <Extension Id="com.higgesfield.panel" Version="0.1.0"/>
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <!-- Premiere Pro 2024 (24.0) and newer. Add AEFT here to also load in After Effects. -->
      <Host Name="PPRO" Version="[24.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <!-- CSXS 9.0 == CEP 11 (Premiere 2024). -->
      <RequiredRuntime Name="CSXS" Version="9.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.higgesfield.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./client/index.html</MainPath>
          <ScriptPath>./host/index.jsx</ScriptPath>
          <CEFCommandLine>
            <!-- Node.js + mixed context so the panel can require('https'),
                 require('fs'), require('crypto') and still reach window.__adobe_cep__. -->
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
            <Parameter>--allow-file-access</Parameter>
            <Parameter>--allow-file-access-from-files</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Higgesfield</Menu>
          <Geometry>
            <Size><Height>680</Height><Width>400</Width></Size>
            <MinSize><Height>420</Height><Width>320</Width></MinSize>
            <MaxSize><Height>2000</Height><Width>900</Width></MaxSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
